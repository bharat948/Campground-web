<% layout('layouts/boilerplate') %>
    <% const memberSince=user._id && typeof user._id.getTimestamp==='function' ?
        user._id.getTimestamp().toLocaleDateString('en-US', { year: 'numeric' , month: 'long' }) : '' ; %>

        <div class="yc-profile-header">
            <div class="container">
                <div class="profile-avatar">
                    <%= user.username.charAt(0).toUpperCase() %>
                </div>
                <h1>
                    <%= user.username %>
                </h1>
                <p class="profile-since">Member since <%= memberSince %>
                </p>
                <div class="profile-stats">
                    <span class="stat-pill">
                        <%= campgrounds.length %> Campgrounds
                    </span>
                    <span class="stat-pill">
                        <%= reviews.length %> Reviews
                    </span>
                </div>
            </div>
        </div>

        <section class="yc-profile-section">
            <h2>My Campgrounds</h2>
            <% if (campgrounds.length===0) { %>
                <div class="yc-empty-state">
                    <span class="empty-icon">🏕</span>
                    <p>No campgrounds yet.</p>
                    <a href="/campgrounds/new" class="btn btn-success">Add Your First Campground</a>
                </div>
                <% } else { %>
                    <div class="row">
                        <% for (let camp of campgrounds) { %>
                            <div class="col-md-4 col-sm-6 mb-4">
                                <div class="yc-camp-card">
                                    <div class="card-img-wrap">
                                        <% if (camp.images && camp.images.length) { %>
                                            <img src="<%= camp.images[0].url %>" alt="<%= camp.title %>">
                                            <% } else { %>
                                                <span class="card-img-placeholder">🏕</span>
                                                <% } %>
                                    </div>
                                    <div class="card-body">
                                        <h5 class="camp-title">
                                            <%= camp.title %>
                                        </h5>
                                        <p class="camp-location">📍 <%= camp.location || '' %>
                                        </p>
                                        <span class="camp-price">$<%= camp.price %>/night</span>
                                        <a href="/campgrounds/<%= camp._id %>" class="btn-view">View →</a>
                                    </div>
                                </div>
                            </div>
                            <% } %>
                    </div>
                    <% } %>
        </section>

        <section class="yc-profile-section">
            <h2>My Reviews</h2>
            <% if (reviews.length===0) { %>
                <div class="yc-empty-state">
                    <span class="empty-icon">⭐</span>
                    <p>No reviews yet.</p>
                    <a href="/campgrounds" class="btn btn-success">Explore Campgrounds</a>
                </div>
                <% } else { %>
                    <% for (let review of reviews) { %>
                        <div class="card yc-review-hcard mb-3">
                            <div class="card-body d-flex justify-content-between align-items-start flex-wrap"
                                style="gap:12px;">
                                <div>
                                    <p class="mb-1" style="font-weight:500;">
                                        <% if (review.campground) { %>
                                            <a href="/campgrounds/<%= review.campground._id %>"
                                                style="color:var(--color-primary);">
                                                <%= review.campground.title %>
                                            </a>
                                            <% } else { %>
                                                —
                                                <% } %>
                                    </p>
                                    <p class="mb-0"
                                        style="color:var(--color-text-secondary);font-size:0.9rem;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;">
                                        <%= review.body %>
                                    </p>
                                </div>
                                <div class="text-right">
                                    <span style="color:var(--color-accent);font-weight:600;">⭐ <%= review.rating %>
                                            /5</span>
                                </div>
                            </div>
                        </div>
                        <% } %>
                            <% } %>
        </section>