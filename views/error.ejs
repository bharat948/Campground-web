<% layout('layouts/boilerplate') %>

    <div class="yc-error-page">
        <div class="yc-error-code">
            <%= (typeof err !=='undefined' && err && err.statusCode) ? err.statusCode : 500 %>
        </div>
        <div class="yc-error-content">
            <span class="yc-error-icon">
                <% if (typeof err !=='undefined' && err && err.statusCode===404) { %>
                    🗺️
                    <% } else { %>
                        ⚠️
                        <% } %>
            </span>
            <h2 class="font-playfair mb-3" style="font-size:1.8rem;">
                <%= (typeof err !=='undefined' && err && err.message) ? err.message : 'Something went wrong' %>
            </h2>
            <% if (process.env.NODE_ENV !=='production' && typeof err !=='undefined' && err && err.stack) { %>
                <pre
                    style="text-align:left;font-size:0.75em;background:var(--color-surface);padding:var(--space-sm);border-radius:var(--radius-sm);max-height:200px;overflow:auto;border:1px solid var(--color-border);margin-bottom:var(--space-md);"><%= err.stack %></pre>
                <% } %>
                    <div class="yc-error-actions">
                        <a href="/" class="btn btn-primary">Go Home</a>
                        <a href="javascript:history.back()" class="btn btn-outline-primary">Go Back</a>
                    </div>
        </div>
    </div>