<% if(typeof success !=='undefined' && success && success.length){ %>
    <div class="alert alert-success alert-dismissible fade show yc-flash" role="alert">
        ✓ <%=success %>
            <button class="close" type="button" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
    </div>
    <% } %>

        <% if(typeof error !=='undefined' && error && error.length){ %>
            <div class="alert alert-danger alert-dismissible fade show yc-flash" role="alert">
                ⚠ <%=error %>
                    <button class="close" type="button" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
            </div>
            <% } %>