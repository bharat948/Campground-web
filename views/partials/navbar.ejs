<nav class="navbar navbar-expand-lg navbar-light yc-navbar">
    <a class="navbar-brand" href="/">🏕 YelpCamp</a>
    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNavAltMarkup"
        aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
        <div class="navbar-nav">
            <a class="nav-item nav-link" href="/">Home <span class="sr-only">(current)</span></a>
            <a class="nav-item nav-link" href="/campgrounds">Campgrounds</a>
            <a class="nav-item nav-link" href="/campgrounds/new">New Campground</a>
        </div>
        <div class="navbar-nav ml-auto align-items-center">
            <% if (typeof currentUser==='undefined' || !currentUser){ %>
                <a class="yc-btn-login mr-2" href="/login">Login</a>
                <a class="yc-btn-register" href="/register">Register</a>
                <% } else { %>
                    <div class="nav-item dropdown yc-notifications-dropdown">
                        <a class="nav-link yc-notifications-toggle dropdown-toggle" href="#" id="notificationsDropdown"
                            role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <span class="yc-notifications-bell" aria-hidden="true">🔔</span>
                            <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
                                <span class="yc-notifications-badge"><%= unreadCount %></span>
                            <% } %>
                            <span class="sr-only">Notifications</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-right yc-notifications-menu"
                            aria-labelledby="notificationsDropdown">
                            <h6 class="dropdown-header">Notifications</h6>
                            <% const notifs = (typeof notifications !== 'undefined' && notifications) ? notifications : []; %>
                            <% if (notifs.length === 0) { %>
                                <span class="dropdown-item-text yc-notifications-empty">No notifications yet</span>
                            <% } else { %>
                                <% for (let notif of notifs) { %>
                                    <form action="/notifications/<%= notif._id %>/read" method="post"
                                        class="yc-notification-item-form">
                                        <%- include('csrf') %>                                        <button type="submit"
                                            class="dropdown-item yc-notification-item <%= notif.read ? '' : 'yc-notification-unread' %>">
                                            <span class="yc-notification-message">
                                                <strong><%= notif.actor.username %></strong>
                                                <%= notif.type === 'like' ? ' liked your review' : ' replied to your review' %>
                                            </span>
                                            <span class="yc-notification-camp"><%= notif.campground.title %></span>
                                            <span class="yc-notification-time">
                                                <%= notif.createdAt ? new Date(notif.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '' %>
                                            </span>
                                        </button>
                                    </form>
                                <% } %>
                            <% } %>
                            <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
                                <div class="dropdown-divider"></div>
                                <form action="/notifications/read-all" method="post" class="yc-mark-all-read-form">
                                    <%- include('csrf') %>                                    <button type="submit" class="dropdown-item yc-mark-all-read">Mark all as read</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                    <a class="nav-item nav-link d-flex align-items-center" href="/users/<%= currentUser._id %>"
                        style="gap:8px;">
                        <span class="yc-avatar">
                            <%= currentUser.username.charAt(0).toUpperCase() %>
                        </span>
                        <span>
                            <%= currentUser.username %>
                        </span>
                    </a>
                    <a class="yc-logout-link" href="/logout">Logout</a>
                    <% } %>
        </div>
    </div>
</nav>