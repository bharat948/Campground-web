<% layout('layouts/boilerplate')%>
    <link rel="stylesheet" href="/stylesheets/stars.css">

    <div class="row mt-2">
        <div class="col-lg-7 mb-4">
            <!-- Carousel -->
            <div class="yc-carousel">
                <div id="campgroundCarousel" class="carousel slide" data-ride="carousel">
                    <div class="carousel-inner">
                        <% campground.images.forEach((image, i)=>{ %>
                            <div class="carousel-item <%= i === 0 ? 'active': ''%>">
                                <img class="d-block w-100" src="<%= image.url %>" alt="<%= campground.title %>">
                            </div>
                            <% }) %>
                    </div>
                    <% if(campground.images.length>1) {%>
                        <a class="carousel-control-prev" href="#campgroundCarousel" role="button" data-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="sr-only">Previous</span>
                        </a>
                        <a class="carousel-control-next" href="#campgroundCarousel" role="button" data-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="sr-only">Next</span>
                        </a>
                        <% }%>
                </div>
            </div>

            <!-- Map -->
            <div id='map' style='width: 100%; height: 300px;'></div>
        </div>

        <div class="col-lg-5">
            <!-- Detail card -->
            <div class="mb-4">
                <h1 class="yc-detail-title">
                    <%= campground.title %>
                </h1>
                <p class="yc-detail-location">📍 <%= campground.location %>
                </p>
                <div class="yc-detail-price mb-3">
                    <span class="price-amount">$<%= campground.price %></span>
                    <span class="price-unit">/night</span>
                </div>
                <p class="yc-detail-author">
                    Posted by <a href="/users/<%= campground.author._id %>">
                        <%= campground.author.username %>
                    </a>
                </p>
                <p class="yc-detail-desc">
                    <%= campground.description %>
                </p>

                <% if( currentUser && campground.author._id.equals(currentUser._id)) {%>
                    <div class="yc-detail-actions mb-3">
                        <a class="btn btn-info" href="/campgrounds/<%=campground._id %>/edit">Edit</a>
                        <form class="d-inline" action="/campgrounds/<%=campground._id %>?_method=DELETE" method="post">
                            <%- include('../partials/csrf') %>                            <button class="btn btn-outline-danger">Delete</button>
                        </form>
                    </div>
                    <% }%>
            </div>

            <!-- Reviews -->
            <div>
                <span class="yc-reviews-heading">Reviews</span>
                <span class="yc-review-count">
                    <%= campground.reviews.length %> reviews
                </span>
            </div>

            <% if(currentUser){%>
                <div class="yc-review-form mt-3">
                    <h4>Share Your Experience</h4>
                    <form action="/campgrounds/<%= campground._id %>/reviews" method="post" class="validated-form"
                        novalidate>
                        <%- include('../partials/csrf') %>                        <div class="mb-3">
                            <fieldset class="starability-basic">
                                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1"
                                    checked aria-label="No rating." />
                                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                <label for="first-rate1" title="Terrible">1 star</label>
                                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                <label for="first-rate2" title="Not good">2 stars</label>
                                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                <label for="first-rate3" title="Average">3 stars</label>
                                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                <label for="first-rate4" title="Very good">4 stars</label>
                                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                <label for="first-rate5" title="Amazing">5 stars</label>
                            </fieldset>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="body">Your Review</label>
                            <textarea class="form-control" name="review[body]" id="body" cols="30" rows="3" required
                                placeholder="Tell us about your experience..."></textarea>
                            <div class="valid-feedback">Looks good!</div>
                        </div>
                        <button class="btn btn-success">Submit Review</button>
                    </form>
                </div>
                <% }%>

                    <% for(let review of campground.reviews){ %>
                        <% const likes = review.likes || []; %>
                        <% const isLiked = currentUser && likes.some(likeId => likeId.equals(currentUser._id)); %>
                        <% const replies = review.replies || []; %>
                        <div class="card yc-review-card">
                            <div class="card-body">
                                <div class="review-author">
                                    <span class="yc-avatar" style="width:28px;height:28px;font-size:0.7rem;">
                                        <%= review.author.username.charAt(0).toUpperCase() %>
                                    </span>
                                    <a href="/users/<%= review.author._id %>"
                                        style="color:var(--color-text-primary);font-weight:500;text-decoration:none;">
                                        <%= review.author.username %>
                                    </a>
                                </div>
                                <p class="starability-result" data-rating="<%= review.rating%>">
                                    rated:<%= review.rating%> stars
                                </p>
                                <p class="review-body">
                                    <%= review.body %>
                                </p>
                                <div class="yc-review-actions">
                                    <span class="yc-like-count"><%= likes.length %> <%= likes.length === 1 ? 'like' : 'likes' %></span>
                                    <% if (currentUser) { %>
                                        <form
                                            action="/campgrounds/<%= campground._id %>/reviews/<%= review._id %>/like"
                                            method="post" class="d-inline">
                                            <%- include('../partials/csrf') %>                                            <button type="submit"
                                                class="btn btn-sm yc-like-btn <%= isLiked ? 'yc-like-btn-active' : '' %>">
                                                <%= isLiked ? 'Unlike' : 'Like' %>
                                            </button>
                                        </form>
                                    <% } %>
                                    <% if( currentUser && review.author.equals(currentUser._id)) {%>
                                        <form
                                            action="/campgrounds/<%=campground._id%>/reviews/<%= review._id %>?_method=DELETE"
                                            method="post" class="d-inline">
                                            <%- include('../partials/csrf') %>                                            <button class="btn btn-outline-danger btn-sm btn-delete-review">Delete</button>
                                        </form>
                                    <% }%>
                                </div>

                                <% if (replies.length > 0) { %>
                                    <div class="yc-replies">
                                        <% for (let reply of replies) { %>
                                            <div class="yc-reply">
                                                <div class="yc-reply-header">
                                                    <span class="yc-avatar" style="width:24px;height:24px;font-size:0.65rem;">
                                                        <%= reply.author.username.charAt(0).toUpperCase() %>
                                                    </span>
                                                    <a href="/users/<%= reply.author._id %>"
                                                        style="color:var(--color-text-primary);font-weight:500;text-decoration:none;font-size:0.9rem;">
                                                        <%= reply.author.username %>
                                                    </a>
                                                    <span class="yc-reply-date">
                                                        <%= reply.createdAt ? new Date(reply.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '' %>
                                                    </span>
                                                </div>
                                                <p class="yc-reply-body"><%= reply.body %></p>
                                                <% if (currentUser && reply.author.equals(currentUser._id)) { %>
                                                    <form
                                                        action="/campgrounds/<%= campground._id %>/reviews/<%= review._id %>/replies/<%= reply._id %>?_method=DELETE"
                                                        method="post" class="d-inline">
                                                        <%- include('../partials/csrf') %>                                                        <button class="btn btn-outline-danger btn-sm btn-delete-reply">Delete</button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        <% } %>
                                    </div>
                                <% } %>

                                <% if (currentUser) { %>
                                    <form
                                        action="/campgrounds/<%= campground._id %>/reviews/<%= review._id %>/replies"
                                        method="post" class="yc-reply-form validated-form" novalidate>
                                        <%- include('../partials/csrf') %>                                        <div class="form-group mb-2">
                                            <label class="form-label sr-only" for="reply-body-<%= review._id %>">Reply</label>
                                            <textarea class="form-control form-control-sm" name="reply[body]"
                                                id="reply-body-<%= review._id %>" rows="2" required
                                                placeholder="Write a reply..."></textarea>
                                        </div>
                                        <button class="btn btn-sm btn-outline-primary">Reply</button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                        <% } %>
        </div>
    </div>

    <script>
        const mapToken = `<%-process.env.MAPBOX_TOKEN%>`;
        const lang = JSON.parse('<%= campground.geometry.coordinates[0]%>');
        const lot = JSON.parse('<%= campground.geometry.coordinates[1]%>');
        mapboxgl.accessToken = mapToken;
        const map = new mapboxgl.Map({
            container: 'map',
            style: 'mapbox://styles/mapbox/streets-v11',
            center: [lang, lot],
            zoom: 13
        })
        new mapboxgl.Marker()
            .setLngLat([lang, lot])
            .addTo(map);
    </script>