PORT=3000
NODE_ENV=development
MONGO_URL=
SESSION_SECRET=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Mapbox (maps and geocoding; use a public token with URL restrictions)
MAPBOX_TOKEN=

# Local seed script only (npm run seed) — never use in production
SEED_USER_PASSWORD=

# For production deployment, set NODE_ENV=production and fill every variable above
# except SEED_USER_PASSWORD.
